# Production template — copy to .env on the VPS / Render host.
# Keys and URLs here may differ from your local .env; never assume they match.

ENVIRONMENT=production
SECRET_KEY=change-me-in-production

FRONTEND_URL=https://frontend-jet-ten-16.vercel.app
CORS_ORIGINS=https://frontend-jet-ten-16.vercel.app

# LLM: cc-vibe Claude Haiku for chat; OpenRouter for embeddings
OPENROUTER_API_KEY=
OWNNBLM_LLM_PROVIDER=anthropic
OWNNBLM_ANTHROPIC_BASE_URL=https://cc-vibe.com
OWNNBLM_ANTHROPIC_API_KEY=
DEFAULT_LLM_MODEL=claude-haiku-4-5-20251001
DEFAULT_EMBED_MODEL=openai/text-embedding-3-small

DATABASE_URL=postgresql://ownnblm:ownnblm@postgres:5432/ownnblm
REDIS_URL=redis://redis:6379/0
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=/data/files

AUTH_RESTRICTED=true
AUTH_ALLOWLIST_EMAILS=

RESEND_API_KEY=
DIGEST_FROM_EMAIL=ownNBLM <onboarding@resend.dev>

PAYMENT_PROVIDER=razorpay
BILLING_CURRENCY=INR
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_PERSONAL=
RAZORPAY_PLAN_TEAM=
RAZORPAY_PLAN_BUSINESS=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

LLM_BUDGET_ENABLED=true
LLM_BUDGET_USD=0.005
LLM_BUDGET_WINDOW_HOURS=48
LLM_BUDGET_SCOPE=global
LLM_MAX_OUTPUT_TOKENS=512
LLM_RETRIEVAL_TOP_K=5
LLM_MAX_CHUNK_CHARS=800

SENTRY_DSN=
POSTGRES_PASSWORD=ownnblm
