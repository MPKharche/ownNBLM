# Required — synced from ../PageIndex/.env via: make sync-key
OPENROUTER_API_KEY=sk-or-v1-your-key-here

ENVIRONMENT=development
SECRET_KEY=change-me-in-production
DATABASE_URL=sqlite:///./ownNBLM.db
REDIS_URL=
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./data/files
DEFAULT_LLM_MODEL=openai/gpt-4o-mini
DEFAULT_EMBED_MODEL=openai/text-embedding-3-small
MAX_CONCURRENT_INGEST=3
MAX_FILE_SIZE_MB=50
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_URL=http://localhost:5173

# Local dev only — when port 8000 has a zombie listener (Windows), point Vite proxy elsewhere:
# VITE_DEV_API_PROXY=http://127.0.0.1:8001

# Billing — Razorpay (default). Leave empty while registration is pending.
# See docs/BILLING_RAZORPAY.md and docs/PROD_RESUME.md
PAYMENT_PROVIDER=razorpay
BILLING_CURRENCY=INR
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_PERSONAL=
RAZORPAY_PLAN_TEAM=
RAZORPAY_PLAN_BUSINESS=

# Email (magic link + weekly digest) — Resend
RESEND_API_KEY=
DIGEST_FROM_EMAIL=ownNBLM <onboarding@resend.dev>

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Business-tier dedicated stacks (optional)
PORTAINER_URL=
PORTAINER_API_KEY=
FOLDER_WATCH_ENABLED=true

# Stripe (optional — not required in India)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PERSONAL=
STRIPE_PRICE_TEAM=
STRIPE_PRICE_BUSINESS=

# Production only
SENTRY_DSN=
POSTGRES_PASSWORD=ownnblm

# LLM burn control (USD) — default caps total spend at $0.005 (0.5¢) per 48h
LLM_BUDGET_ENABLED=true
LLM_BUDGET_USD=0.005
LLM_BUDGET_WINDOW_HOURS=48
LLM_BUDGET_SCOPE=global
LLM_MAX_OUTPUT_TOKENS=512
LLM_RETRIEVAL_TOP_K=5
LLM_MAX_CHUNK_CHARS=800
# OpenRouter list prices per 1M tokens (adjust if you change models)
LLM_PRICE_INPUT_PER_MTOK=0.15
LLM_PRICE_OUTPUT_PER_MTOK=0.60
LLM_PRICE_EMBED_PER_MTOK=0.02
