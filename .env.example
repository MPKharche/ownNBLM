# Local development template — copy to .env and fill in your keys.
# .env is gitignored; production secrets live on the VPS and may differ.

ENVIRONMENT=development
SECRET_KEY=dev-secret-change-in-production

FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Sync from sibling project: make sync-key
OPENROUTER_API_KEY=sk-or-v1-your-key-here
DEFAULT_LLM_MODEL=openai/gpt-4o-mini
DEFAULT_EMBED_MODEL=openai/text-embedding-3-small

# Optional: Anthropic-compatible proxy for chat (embeddings still use OpenRouter)
# OWNNBLM_LLM_PROVIDER=anthropic
# OWNNBLM_ANTHROPIC_BASE_URL=https://cc-vibe.com
# OWNNBLM_ANTHROPIC_API_KEY=sk-your-token
# DEFAULT_LLM_MODEL=claude-sonnet-4-20250514

DATABASE_URL=sqlite:///./ownNBLM.db
REDIS_URL=
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./data/files

AUTH_RESTRICTED=true
AUTH_ALLOWLIST_EMAILS=admin@ownnblm.local

RESEND_API_KEY=
DIGEST_FROM_EMAIL=ownNBLM <onboarding@resend.dev>

PAYMENT_PROVIDER=razorpay
BILLING_CURRENCY=INR

LLM_BUDGET_ENABLED=true
LLM_BUDGET_USD=0.005
LLM_BUDGET_WINDOW_HOURS=48
LLM_BUDGET_SCOPE=global
LLM_MAX_OUTPUT_TOKENS=512
LLM_RETRIEVAL_TOP_K=5
LLM_MAX_CHUNK_CHARS=800

# Windows: if port 8000 is blocked, set in frontend/.env.development.local:
# VITE_DEV_API_PROXY=http://127.0.0.1:8001
