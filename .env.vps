# VPS production environment — lm.planetfinance.cloud
# Copy this file to .env on your VPS and fill in the blanks.
# docker-compose -f docker-compose.full.yml up -d

ENVIRONMENT=production

# ──────────────── Security ────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# ──────────────── Domain ────────────────
FRONTEND_URL=https://lm.planetfinance.cloud
CORS_ORIGINS=https://lm.planetfinance.cloud
# Leave empty — no Vercel, no regex needed
CORS_ORIGIN_REGEX=

# ──────────────── Database ────────────────
POSTGRES_PASSWORD=CHANGE_ME_strong_password
# DATABASE_URL is injected by docker-compose.full.yml — no need to set here

# ──────────────── LLM ────────────────
# Option A: OpenRouter (default)
OPENROUTER_API_KEY=

# Option B: Anthropic via cc-vibe proxy
OWNNBLM_LLM_PROVIDER=anthropic
OWNNBLM_ANTHROPIC_BASE_URL=https://cc-vibe.com
OWNNBLM_ANTHROPIC_API_KEY=

DEFAULT_LLM_MODEL=claude-haiku-4-5-20251001
DEFAULT_EMBED_MODEL=openai/text-embedding-3-small

# ──────────────── Storage ────────────────
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=/app/data/files

# ──────────────── Auth ────────────────
AUTH_RESTRICTED=true
# Comma-separated list of allowed email addresses
AUTH_ALLOWLIST_EMAILS=

# ──────────────── Email (optional) ────────────────
RESEND_API_KEY=
DIGEST_FROM_EMAIL=ownNBLM <onboarding@resend.dev>

# ──────────────── Billing (optional) ────────────────
PAYMENT_PROVIDER=razorpay
BILLING_CURRENCY=INR
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_PERSONAL=
RAZORPAY_PLAN_TEAM=
RAZORPAY_PLAN_BUSINESS=

# ──────────────── Google OAuth (optional) ────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ──────────────── LLM Budget ────────────────
LLM_BUDGET_ENABLED=true
LLM_BUDGET_USD=0.005
LLM_BUDGET_WINDOW_HOURS=48
LLM_BUDGET_SCOPE=global
LLM_MAX_OUTPUT_TOKENS=512
LLM_RETRIEVAL_TOP_K=5
LLM_MAX_CHUNK_CHARS=800

# ──────────────── Observability (optional) ────────────────
SENTRY_DSN=
